# Mindloom Receiver — переменные окружения
# Скопируйте этот файл в .env.local и заполните значения
# НЕ коммитьте .env.local в git

# Секрет для авторизации Mindloom GPT (Bearer token)
# Генерация: openssl rand -base64 32
MINDLOOM_WEBHOOK_SECRET=

# Учётные данные для /admin/* (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Путь к SQLite базе данных
# По умолчанию: ./data/mindloom.db (относительно корня проекта)
DATABASE_PATH=./data/mindloom.db

# Базовый URL сервиса (без trailing slash)
# Локально: http://localhost:3000
# На сервере: https://mindloom.edagency.ru
BASE_URL=http://localhost:3000

# URL receiver для отправки тестовых отчётов через submit:sample
# Локально: http://localhost:3000
# На сервере: https://mindloom.edagency.ru
RECEIVER_URL=https://mindloom.edagency.ru

# Порт (используется PM2 на сервере)
PORT=3000

# Окружение
NODE_ENV=development
