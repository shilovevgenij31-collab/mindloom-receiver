# Mindloom Receiver — production environment
# ИНСТРУКЦИЯ: создать этот файл вручную на сервере как .env.production
# НЕ копировать локальные .env файлы на сервер
# НЕ коммитить .env.production в git

# Секрет для авторизации Mindloom GPT (Bearer token)
# Генерация на сервере: openssl rand -base64 32
MINDLOOM_WEBHOOK_SECRET=

# Учётные данные для /admin/* (HTTP Basic Auth)
# Генерация на сервере: openssl rand -base64 16
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Путь к SQLite внутри контейнера (соответствует bind mount в docker-compose)
DATABASE_PATH=/app/data/mindloom.db

# Публичный URL сервиса
BASE_URL=https://mindloom.edagency.ru

# Порт внутри контейнера
PORT=3000

NODE_ENV=production
